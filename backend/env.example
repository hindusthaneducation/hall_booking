DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root@123
DB_NAME=hall_booking_system
JWT_SECRET=super_secret_jwt_key_change_in_production
PORT=3000

# SendGrid API Config (Optional - will fallback to Gmail SMTP if empty)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=no-reply@hindusthan.net

# WhatsApp API Config (Fill in only ONE of the following provider sections)

# Option 1: Twilio WhatsApp Gateway
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Option 2: Meta / Facebook WhatsApp Business Cloud API
WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# Option 3: Custom/Generic HTTP API Gateway (GET or POST URL)
# Placeholders {{phone}} (with + country code) or {{phone_raw}} (digits only) and {{message}}
WHATSAPP_API_URL=https://api.example.com/send?apikey=123&to={{phone}}&message={{message}}
WHATSAPP_API_METHOD=GET
WHATSAPP_API_HEADERS={"Authorization": "Bearer token"}
WHATSAPP_API_BODY={"to": "{{phone_raw}}", "message": "{{message}}"}
